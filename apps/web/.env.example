# =============================================================================
# NEXT.JS WEB APP ENVIRONMENT VARIABLES
# =============================================================================
# Minimal runtime env for the simplified static starter.

# -----------------------------------------------------------------------------
# 🌐 APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# 🔐 GITHUB AUTH
# -----------------------------------------------------------------------------
# GitHub OAuth app credentials
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session signing secret for Auth.js / NextAuth
# Generate a long random string for local and production environments
NEXTAUTH_SECRET=

# -----------------------------------------------------------------------------
# 📊 ANALYTICS
# -----------------------------------------------------------------------------
# Optional Google Tag Manager container ID.
NEXT_PUBLIC_GTM_ID=

# -----------------------------------------------------------------------------
# 🔄 OPTIONAL ROOT-LEVEL ENV
# -----------------------------------------------------------------------------
# If you use repo tooling outside the web app, those scripts may still rely on:
# - GITHUB_TOKEN
