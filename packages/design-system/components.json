{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "styles/globals.css",
    "baseColor": "neutral",
    "cssVariables": true
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@thedaviddias/design-system/components",
    "utils": "@thedaviddias/design-system/lib/utils",
    "hooks": "@thedaviddias/design-system/hooks",
    "lib": "@thedaviddias/design-system/lib",
    "ui": "@thedaviddias/design-system/components/shadcn"
  },
  "registries": {
    "@shadcnblocks": {
      "url": "https://www.shadcnblocks.com/r/{name}",
      "headers": {
        "Authorization": "Bearer ${SHADCNBLOCKS_API_KEY}"
      }
    }
  }
}
