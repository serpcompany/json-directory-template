{
  "name": "llms-txt-hub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm tsx scripts/search-index-generator.ts && turbo build",
    "build:pages": "pnpm build:site",
    "build:site": "pnpm tsx scripts/build-site.ts",
    "check:links": "lychee --config ./lychee.toml --verbose .",
    "clean": "git clean -xdf node_modules dist .next",
    "clean:workspaces": "turbo clean",
    "commit": "cz",
    "dev": "pnpm dev:site -- --site serpdownloaders.com",
    "dev:all": "cross-env FORCE_COLOR=1 turbo dev --parallel",
    "dev:operator": "pnpm tsx scripts/dev-operator.ts",
    "dev:serpdownloaders": "pnpm dev:site -- --site serpdownloaders.com",
    "dev:serpsoftware": "pnpm dev:site -- --site serp.software",
    "dev:pornvideodownloaders": "pnpm dev:site -- --site pornvideodownloaders.com",
    "dev:starter": "pnpm --filter starter dev",
    "dev:site": "pnpm tsx scripts/dev-site.ts",
    "format": "biome check --write .",
    "generate-search-index": "pnpm tsx scripts/search-index-generator.ts",
    "normalize:listing-logos": "pnpm tsx scripts/normalize-listing-logos-to-png.ts",
    "prepare:site": "pnpm tsx scripts/site-data.ts",
    "sync:network-brands": "pnpm tsx scripts/sync-network-brands.ts",
    "sync:listing-logos": "pnpm tsx scripts/sync-listing-logos.ts",
    "validate-data": "tsx scripts/validate-data.ts",
    "validate:listings": "tsx scripts/validate-data.ts",
    "validate:site": "pnpm tsx scripts/validate-site.ts",
    "validate:sites": "pnpm tsx scripts/validate-active-sites.ts",
    "audit:sitemaps": "pnpm tsx scripts/audit-sitemaps.ts",
    "deploy": "pnpm deploy:site",
    "deploy:site": "pnpm tsx scripts/deploy-site.ts",
    "generate:badges": "tsx scripts/generate-badges.ts",
    "inventory:badges": "node scripts/inventory-featured-badges.mjs",
    "inventory:r2-badges": "node scripts/inventory-r2-featured-badges.mjs",
    "qc:badges": "pnpm exec vitest run scripts/featured-badge-assets.test.ts scripts/featured-badge-r2-assets.test.ts scripts/logo-assets.test.ts",
    "r2:sync-badges": "node scripts/sync-featured-badges-r2.mjs",
    "submissions": "tsx scripts/submissions.ts",
    "test:submission-flow": "tsx scripts/test-submission-flow.ts",
    "generate:llms": "pnpm --filter generator start",
    "generate:site-wrapper": "pnpm tsx scripts/generate-site-wrapper.ts",
    "generate:website": "turbo gen website",
    "postinstall": "manypkg fix",
    "lint": "pnpm lint:forbidden-links && turbo lint && manypkg check",
    "lint:fix": "turbo lint:fix && manypkg fix && pnpm biome lint --write .",
    "lint:forbidden-links": "node scripts/lint-forbidden-links.mjs",
    "audit:forbidden-links": "node scripts/lint-forbidden-links.mjs --generated",
    "shadcn": "cd packages/design-system && pnpm dlx shadcn@canary add",
    "start": "turbo run start",
    "test": "turbo test --cache-dir=.turbo",
    "test:e2e": "turbo test:e2e --filter=e2e",
    "test:e2e:smoke": "turbo test:e2e:smoke --filter=e2e",
    "test:e2e:ui": "turbo test:e2e:ui --filter=e2e",
    "test:e2e:debug": "turbo test:e2e:debug --filter=e2e",
    "test:repo": "pnpm exec vitest run scripts/pr-review-workflow.test.ts scripts/labels-workflow.test.ts scripts/update-listings-json-workflow.test.ts scripts/ci-workflow-install.test.ts scripts/build-and-deploy-workflow.test.ts scripts/next-config-build-id.test.ts scripts/validate-active-sites.test.ts scripts/validate-data.test.ts scripts/generate-site-wrapper.test.ts scripts/thin-wrapper-runtime.test.ts scripts/web-core-runtime-boundary.test.ts scripts/site-config.test.ts scripts/network-brands.test.ts scripts/sync-network-brands.test.ts scripts/sitemap-files.test.ts scripts/audit-sitemaps.test.ts scripts/build-artifact-pruning.test.ts scripts/submit-gsc-sitemaps.test.ts scripts/deploy-site.test.ts scripts/deploy-to-repo-script.test.ts scripts/import-downloaders-from-sheet.test.ts scripts/eslint-rules/no-forbidden-listing-links.test.ts scripts/footer-dr-badge.test.ts scripts/featured-badge-assets.test.ts scripts/featured-badge-r2-assets.test.ts packages/web-core/src/category-routes/schema-dates.test.tsx",
    "test:watch": "turbo test:watch --cache-dir=.turbo",
    "typecheck": "turbo typecheck",
    "update": "pnpm update -r",
    "contributors:add": "all-contributors add",
    "contributors:generate": "all-contributors generate",
    "contributors:check": "all-contributors check"
  },
  "devDependencies": {
    "@auto-it/all-contributors": "^11.3.6",
    "@auto-it/first-time-contributor": "^11.3.6",
    "@biomejs/biome": "2.2.2",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@content-collections/mdx": "^0.2.2",
    "@manypkg/cli": "^0.23.0",
    "@thedaviddias/site-contract": "workspace:*",
    "@thedaviddias/web-core": "workspace:*",
    "@turbo/gen": "^2.8.7",
    "@types/js-yaml": "^4.0.9",
    "@types/validator": "^13.15.10",
    "acorn": "^8.15.0",
    "all-contributors-cli": "^6.26.1",
    "chalk": "^5.6.2",
    "cross-env": "^7.0.3",
    "csv-parse": "^6.1.0",
    "dompurify": "^3.3.1",
    "eslint": "^10.4.0",
    "glob": "^11.1.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "isomorphic-dompurify": "^2.36.0",
    "js-yaml": "^4.1.1",
    "lefthook": "^2.1.1",
    "turbo": "^2.8.7",
    "typescript": "catalog:",
    "validator": "^13.15.26"
  },
  "pnpm": {
    "overrides": {
      "import-in-the-middle": "^1.14.2"
    }
  },
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=24"
  }
}
